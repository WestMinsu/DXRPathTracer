+    bool SaveLinearTextureToPfm(nvrhi::IDevice* device, nvrhi::ITexture* texture, const char* fileName)
+    {
+        if (device == nullptr || texture == nullptr || fileName == nullptr)
+            return false;
+
+        const nvrhi::TextureDesc desc = texture->getDesc();
+        if (desc.format != nvrhi::Format::RGBA32_FLOAT || desc.width == 0 || desc.height == 0)
+            return false;
+
+        nvrhi::CommandListHandle commandList = device->createCommandList();
+        nvrhi::StagingTextureHandle stagingTexture = device->createStagingTexture(desc, nvrhi::CpuAccessMode::Read);
+        commandList->open();
+        commandList->copyTexture(stagingTexture, nvrhi::TextureSlice(), texture, nvrhi::TextureSlice());
+        commandList->close();
+        device->executeCommandList(commandList);
+
+        size_t rowPitch = 0;
+        const uint8_t* mapped = static_cast<const uint8_t*>(device->mapStagingTexture(
+            stagingTexture, nvrhi::TextureSlice(), nvrhi::CpuAccessMode::Read, &rowPitch));
+        if (mapped == nullptr)
+            return false;
+
+        std::ofstream file(std::filesystem::path(fileName), std::ios::binary);
+        file << "PF\n" << desc.width << " " << desc.height << "\n-1.0\n";
+
+        for (int row = static_cast<int>(desc.height) - 1; row >= 0 && file.good(); --row)
+        {
+            const float* source = reinterpret_cast<const float*>(mapped + static_cast<size_t>(row) * rowPitch);
+            for (uint32_t column = 0; column < desc.width; ++column)
+            {
+                file.write(
+                    reinterpret_cast<const char*>(source + static_cast<size_t>(column) * 4),
+                    sizeof(float) * 3);
+            }
+        }
+
+        const bool succeeded = file.good();
+        file.close();
+        device->unmapStagingTexture(stagingTexture);
+        return succeeded;
+    }
+}
